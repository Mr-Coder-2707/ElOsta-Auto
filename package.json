{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "npm run dev:all",
    "dev:web": "vite",
    "dev:api": "tsx watch server/index.ts",
    "dev:all": "concurrently -k -n web,api -c auto \"vite\" \"tsx watch server/index.ts\"",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "clsx": "^2.1.1",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/cors": "^2.8.18",
    "@types/node": "22.19.17",
    "@types/express": "^5.0.3",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "concurrently": "^9.2.1",
    "tailwindcss": "4.1.17",
    "tsx": "^4.20.6",
    "typescript": "5.9.3",
    "vite": "7.2.4",
    "vite-plugin-singlefile": "2.3.0"
  }
}
